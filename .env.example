# Offline mode is the judge-safe, zero-network default.
DEMO_MODE=offline

# Set DEMO_MODE=live only after adding production credentials locally.
# OPENAI_API_KEY=
# Defaults are GPT-5.6 Sol for vision and GPT-5.6 Luna for narration; override
# either role without changing source code when a compatible model is available.
# OPENAI_SOL_MODEL=gpt-5.6-sol
# OPENAI_LUNA_MODEL=gpt-5.6-luna
# Optional fallback when OpenAI is unavailable or out of quota.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3.1-flash-lite
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# EBAY_CLIENT_ID=
# EBAY_CLIENT_SECRET=
# EBAY_MARKETPLACE=EBAY_US
# EBAY_DELIVERY_ZIP=94103
# USE_GPT_BOXES=false
