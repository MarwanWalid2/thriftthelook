# Offline mode is the judge-safe, zero-network default.
DEMO_MODE=offline

# Set DEMO_MODE=live only after adding production credentials locally.
# OPENAI_API_KEY=
# Choose provider/model IDs in your deployment environment; no model is fixed in source.
# OPENAI_SOL_MODEL=
# OPENAI_LUNA_MODEL=
# Optional OpenAI-compatible fallback when the primary provider is unavailable.
# GEMINI_API_KEY=
# GEMINI_MODEL=
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# EBAY_CLIENT_ID=
# EBAY_CLIENT_SECRET=
# EBAY_MARKETPLACE=EBAY_US
# EBAY_DELIVERY_COUNTRY=US
# EBAY_DELIVERY_ZIP=94103
# USE_GPT_BOXES=false
