# Offline mode is the judge-safe, zero-network default.
DEMO_MODE=offline

# Set DEMO_MODE=live only after adding production credentials locally.
# OPENAI_API_KEY=
# For the GPT-5.6 submission path, configure Sol for vision and Luna for narration.
# Any OpenAI-compatible model IDs may be supplied without changing source code.
# OPENAI_SOL_MODEL=gpt-5.6-sol
# OPENAI_LUNA_MODEL=gpt-5.6-luna
# Optional fallback when OpenAI is unavailable or out of quota.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3.1-flash-lite
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# EBAY_CLIENT_ID=
# EBAY_CLIENT_SECRET=
# EBAY_MARKETPLACE=EBAY_US
# EBAY_DELIVERY_ZIP=94103
# USE_GPT_BOXES=false
